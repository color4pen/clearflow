# Database
# PostgreSQL connection URL. Matches the docker-compose.yml defaults.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clearflow

# Auth.js secret key used for signing session tokens.
# Generate a random value with: bunx auth secret
# or: openssl rand -base64 32
AUTH_SECRET=

# Secret used to authenticate requests to internal cron endpoints.
# Set to any random string; keep it confidential.
CRON_SECRET=

# Fixed UUID for the system user created by seed.ts.
# Must match the SYSTEM_USER_ID constant in src/infrastructure/seed.ts.
SYSTEM_USER_ID=00000000-0000-0000-0000-000000000000

# Comma-separated list of super admin email addresses.
# These users can access the /platform route to provision new organizations.
# Leave empty or unset to disable super admin access.
SUPER_ADMIN_EMAILS=
