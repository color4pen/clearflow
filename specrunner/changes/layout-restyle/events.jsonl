everity":"low","resolution":"fixable","file":"src/__tests__/components/dealDetailHeroHeader.test.ts","title":"TC-011/TC-018 (must): ハードコード hex チェックが text-[# のみで bg-[# / border-[# が未検証","rationale":"TC-011 / TC-018 は text-[# / bg-[# / border-[# の全パターン排除を要求しているが、テストは text-[# のみチェックしている。実装ファイルに hex 直書きは存在しないが、テストがこれを捕捉しない。"}],"observations":[{"severity":"low","file":"specrunner/changes/layout-restyle/spec.md","title":"h2 色統一（T-04）に対応する Requirement が spec.md に未追加（既知・前回レビューから継続）","rationale":"spec-review-result-002 で LOW として既出。design.md / tasks.md / T-06 テストで網羅されており実装上の障害はない。"}]},"followUpAttempts":1,"transientRetryAttempts":0},"startedAt":"2026-07-09T14:47:35.428Z","endedAt":"2026-07-09T14:54:31.310Z"}
