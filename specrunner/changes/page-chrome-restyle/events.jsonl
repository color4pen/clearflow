ine":186},{"severity":"low","resolution":"fixable","file":"specrunner/changes/page-chrome-restyle/request.md","title":"tasks 用コンポーネント名の不一致（NewTaskButton vs CreateTaskButton）","rationale":"request.md 要件2 では「例: NewTaskButton」と記載されているが、design.md D2 と T-05 では CreateTaskButton として確定している。機能への影響はないが、両文書を参照する実装者の混乱を招く可能性がある。"}]},"followUpAttempts":1,"transientRetryAttempts":0},"startedAt":"2026-07-10T01:07:52.718Z","endedAt":"2026-07-10T01:13:37.376Z"}
