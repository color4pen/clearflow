{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/.spec-runner/scripts/scan.js 2>&1 | tail -3; node .claude/.spec-runner/scripts/render.js -q"
          }
        ]
      }
    ]
  }
}
